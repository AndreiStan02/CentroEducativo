<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         id="WebApp_ID"
         version="6.0">

    <display-name>no12526</display-name>

<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>no12526</display-name>

    <!-- ================================================================== -->
    <!-- PARÁMETROS DE CONTEXTO                                              -->
    <!-- ================================================================== -->

    <!-- URL base de CentroEducativo -->
    <context-param>
        <param-name>centroEducativoUrl</param-name>
        <param-value>http://localhost:9090/CentroEducativo</param-value>
    </context-param>

    <!-- ================================================================== -->
    <!-- FILTROS                                                             -->
    <!-- ================================================================== -->
	<!--  
	<context-param>
    	<param-name>archivoLog</param-name>
    	<param-value>/logs/no12526.log</param-value>
	</context-param>
	
	<filter>
		<filter-name>Logs</filter-name>
		<filter-class>filtros.FiltroLogs</filter-class>
	</filter>
	
	<filter-mapping>
		<filter-name>Logs</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

	-->
    <!-- ================================================================== -->
    <!-- SERVLETS                                                            -->
    <!-- ================================================================== -->

    <!-- Login: recibe el formulario, autentica contra CentroEducativo -->
    <servlet>
        <servlet-name>Acceso</servlet-name>
        <servlet-class>serverlets.Acceso</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Acceso</servlet-name>
        <url-pattern>/acceso</url-pattern>
    </servlet-mapping>

    <!-- Logout: invalida la sesión y redirige al inicio -->
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>serverlets.Logout</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Configuración del Servlet de Asignaturas de Alumno -->
    <servlet>
        <servlet-name>AsignaturasAlumnoServlet</servlet-name>
        <!-- ¡CAMBIO AQUÍ! Ahora apunta a serverlets -->
        <servlet-class>serverlets.AsignaturasAlumnoServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>AsignaturasAlumnoServlet</servlet-name>
        <url-pattern>/alumno/asignaturas</url-pattern>
    </servlet-mapping>
    
    <!-- ================================================================== -->
    <!-- SESIÓN Y PÁGINA DE INICIO                                           -->
    <!-- ================================================================== -->

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>