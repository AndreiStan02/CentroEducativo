<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         id="WebApp_ID" version="6.0">

    <display-name>nol2526</display-name>

    <!-- ==================== PARÁMETROS GLOBALES ==================== -->
    <context-param>
        <param-name>centroEducativoUrl</param-name>
        <param-value>http://localhost:9090/CentroEducativo</param-value>
    </context-param>

    <context-param>
        <param-name>archivoLog</param-name>
        <param-value>nol2526.log</param-value>
    </context-param>

    <context-param>
        <param-name>logsActivos</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- ==================== FILTROS ==================== -->
    <filter>
        <filter-name>Logs</filter-name>
        <filter-class>filtros.filtroLogs</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>Logs</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== SERVLETS ==================== -->
    <servlet>
        <servlet-name>Acceso</servlet-name>
        <servlet-class>serverlets.Acceso</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Acceso</servlet-name>
        <url-pattern>/acceso</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>serverlets.Logout</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AsignaturasAlumnoServlet</servlet-name>
        <servlet-class>serverlets.AsignaturasAlumnoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AsignaturasAlumnoServlet</servlet-name>
        <url-pattern>/alumno/asignaturas</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DetallesAlumnoServlet</servlet-name>
        <servlet-class>serverlets.DetallesAlumnoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DetallesAlumnoServlet</servlet-name>
        <url-pattern>/alumno/detalles</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AsignaturasProfesorServlet</servlet-name>
        <servlet-class>serverlets.AsignaturasProfesorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AsignaturasProfesorServlet</servlet-name>
        <url-pattern>/profesor/asignaturas</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AlumnosAsignaturaServlet</servlet-name>
        <servlet-class>serverlets.AlumnosAsignaturaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AlumnosAsignaturaServlet</servlet-name>
        <url-pattern>/profesor/alumnos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CalificarAlumnoServlet</servlet-name>
        <servlet-class>serverlets.CalificarAlumnoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CalificarAlumnoServlet</servlet-name>
        <url-pattern>/profesor/nota</url-pattern>
    </servlet-mapping>

    <!-- ==================== PÁGINA DE INICIO ==================== -->
    <welcome-file-list>
        <!-- Actualizado a index.jsp -->
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== SESIÓN ==================== -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- ==================== SEGURIDAD (Estilo Declarativo) ==================== -->
    <security-role>
        <role-name>rolpro</role-name>
    </security-role>
    <security-role>
        <role-name>rolalu</role-name>
    </security-role>

    <!-- Restricciones separadas por rol para coincidir con la lógica del compañero -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Zona alumno</web-resource-name>
            <url-pattern>/alumno/*</url-pattern>
            <url-pattern>/asignaturas_alumno.html</url-pattern>
            <url-pattern>/detalles_alumno.html</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>rolalu</role-name>
        </auth-constraint>
    </security-constraint>

    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Zona profesor</web-resource-name>
            <url-pattern>/profesor/*</url-pattern>
            <url-pattern>/profesor-asignaturas.html</url-pattern>
            <url-pattern>/profesor-evaluacion.html</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>rolpro</role-name>
        </auth-constraint>
    </security-constraint>

    <login-config>
        <auth-method>FORM</auth-method>
        <realm-name>Tomcat User Database Realm</realm-name>
        <form-login-config>
            <!-- Actualizado para usar los archivos JSP -->
            <form-login-page>/login.jsp</form-login-page>
            <form-error-page>/login.jsp?error=invalid</form-error-page>
        </form-login-config>
    </login-config>

    <!-- ==================== ERRORES ==================== -->
    <error-page>
        <error-code>403</error-code>
        <location>/login.jsp?error=2</location>
    </error-page>

    <error-page>
        <error-code>404</error-code>
        <location>/error404.html</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error500.html</location>
    </error-page>

</web-app>